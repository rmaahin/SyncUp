# =============================================================================
# SyncUp Environment Variables
# Copy to .env and fill in values. Never commit .env to version control.
# =============================================================================

# MCP Server URLs (Server-Sent Events transport)
GOOGLE_CALENDAR_MCP_URL=http://localhost:3001/sse
GOOGLE_DOCS_MCP_URL=http://gdocs-mcp:3002/sse
GITHUB_MCP_URL=http://github-mcp:3003/sse

# Trello API (https://developer.atlassian.com/cloud/trello/)
TRELLO_API_KEY=
TRELLO_API_TOKEN=

# GitHub Personal Access Token (for MCP server)
GITHUB_TOKEN=

# GitHub Webhooks — HMAC-SHA256 signature validation
GITHUB_WEBHOOK_SECRET=

# Frontend URL (CORS allowed origin)
FRONTEND_URL=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgresql://syncup:syncup@localhost:5432/syncup

# Redis (async webhook event queue)
REDIS_URL=redis://localhost:6379/0

# Groq API (https://console.groq.com/)
GROQ_API_KEY=

# LLM Model Names (swappable via env; see CLAUDE.md model routing table)
LLM_HIGH_TIER_MODEL=llama-3.3-70b-versatile
LLM_LOW_TIER_MODEL=llama-3.1-8b-instant

# LangSmith Observability
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=syncup

# Google Calendar — course-specific calendar for deadline events
COURSE_CALENDAR_ID=

# ngrok (public tunnel for local webhook development)
# Sign up at https://ngrok.com and get your auth token
NGROK_AUTHTOKEN=

# OAuth Client Credentials (stubs — real flows added later)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
